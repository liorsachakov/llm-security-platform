# =============================================================================
# LLM Security Platform - Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# .env.local is gitignored and will NOT be committed to the repository.
# =============================================================================

# --- Backend API Configuration (REQUIRED) ------------------------------------
# Option 1: Provide the full backend base URL directly
# BACKEND_API_BASE_URL=https://your-api-gateway-id.execute-api.us-east-1.amazonaws.com/prod

# Option 2: Provide origin and stage separately
BACKEND_API_ORIGIN=https://your-api-gateway-id.execute-api.us-east-1.amazonaws.com
BACKEND_API_STAGE=prod
